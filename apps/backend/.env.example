# ============================================================
# AgroClimaX — Variables de Entorno
# Copiar a .env y completar con valores reales
# ============================================================

# Base de datos
DATABASE_URL=postgresql+asyncpg://agroclimax:password@localhost:5432/agroclimax
DATABASE_SYNC_URL=postgresql://agroclimax:password@localhost:5432/agroclimax
DATABASE_USE_POSTGIS=true

# Redis
REDIS_URL=redis://localhost:6379/0

# Copernicus Data Space (https://dataspace.copernicus.eu/)
COPERNICUS_CLIENT_ID=your_client_id
COPERNICUS_CLIENT_SECRET=your_client_secret

# Sentinel Hub (https://www.sentinel-hub.com/)
SENTINELHUB_CLIENT_ID=your_sh_client_id
SENTINELHUB_CLIENT_SECRET=your_sh_client_secret
SENTINELHUB_INSTANCE_ID=your_instance_id

# Copernicus Climate Data Store — ERA5 (https://cds.climate.copernicus.eu/)
CDS_API_KEY=your_cds_api_key
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2

# Área de estudio Rivera, Uruguay
AOI_DEPARTMENT=Rivera
AOI_BBOX_WEST=-57.5
AOI_BBOX_SOUTH=-32.0
AOI_BBOX_EAST=-53.5
AOI_BBOX_NORTH=-30.0

# Pipeline Copernicus
S1_COLLECTION=sentinel-1-grd
S2_COLLECTION=sentinel-2-l2a
PIPELINE_CRON_HOUR=3
PIPELINE_CRON_MINUTE=0
PIPELINE_SCHEDULER_ENABLED=false
PIPELINE_SCHEDULER_POLL_SECONDS=300
PIPELINE_BOOTSTRAP_BACKFILL_DAYS=7
PIPELINE_STALE_AFTER_HOURS=6
PIPELINE_STARTUP_WARMUP_ENABLED=true
APP_RUNTIME_ROLE=all-in-one
TEMPORAL_PREWARM_ENABLED=true
TEMPORAL_PREWARM_SCOPE_TYPE=nacional
TEMPORAL_PREWARM_SCOPE_REF=Uruguay
TEMPORAL_PREWARM_UNIT_ID=
TEMPORAL_PREWARM_DEPARTMENT=
TEMPORAL_PREWARM_TEMPORAL_LAYERS=alerta,rgb,ndmi
TEMPORAL_PREWARM_ZOOM=7
TEMPORAL_PREWARM_WIDTH=1280
TEMPORAL_PREWARM_HEIGHT=720
TEMPORAL_PREWARM_BBOX=
TEMPORAL_PREWARM_HISTORY_DAYS=30
RASTER_PIPELINE_ENABLED=true
RASTER_BACKFILL_DEFAULT_DAYS=365
RASTER_CATALOG_SYNC_DEFAULT_DAYS=30
RASTER_CANONICAL_ZOOM_OPTICAL=14
RASTER_CANONICAL_ZOOM_SAR=14
RASTER_CANONICAL_ZOOM_LST=11
RASTER_CANONICAL_ZOOM_ALERTA=14
SERVE_TILES_INTERNAL=true
INTERNAL_ONLY_LAYERS=
INTERNAL_ONLY_SCOPES=
DISABLE_HEURISTIC_READY=false
RASTER_BACKFILL_PRIORITY_LAYERS=alerta_fusion,rgb,ndmi,sar,ndvi,ndwi,savi,lst
RASTER_CATALOG_DEFAULT_COLLECTIONS=sentinel-2-l2a,sentinel-1-grd,sentinel-3-slstr
RASTER_REFRESH_OPTICAL_DAYS=14
RASTER_REFRESH_SAR_DAYS=7
RASTER_REFRESH_LST_DAYS=3
RASTER_PRODUCT_BUILD_VERSION=raster-v1
RASTER_VISUAL_STYLE_VERSION=visual-v1
TILESERVER_INTERNAL_URL=
TILESERVER_REQUEST_TIMEOUT_SECONDS=20

# Storage / buckets S3-compatible (Railway Bucket, MinIO, etc.)
STORAGE_BACKEND=filesystem
STORAGE_S3_ENDPOINT_URL=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_PREFIX=agroclimax

# Google OAuth / autenticacion
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
GOOGLE_REDIRECT_URI=
PUBLIC_APP_BASE_URL=
AUTH_COOKIE_NAME=agroclimax_session
AUTH_SESSION_TTL_HOURS=72
AUTH_STATE_TTL_MINUTES=10
AUTH_CSRF_HEADER_NAME=X-CSRF-Token
AUTH_LOGIN_SUCCESS_REDIRECT=/

# Umbrales de alerta (humedad %)
ALERT_VERDE_MIN=50
ALERT_AMARILLO_MIN=25
ALERT_NARANJA_MIN=15
# < NARANJA_MIN = ROJO/EMERGENCIA

# Notificaciones
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@agroclimax.uy
SMTP_PASSWORD=your_smtp_password
ALERT_FROM_EMAIL=alerts@agroclimax.uy
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# App
APP_ENV=development
SECRET_KEY=change_this_secret_key_in_production
API_PREFIX=/api/v1
INTEGRATION_SERVICE_TOKENS=
